# ─── Lumio frontend env ───────────────────────────────────────────────────────
# Resolution order: localStorage `lumio.apiOverride` (runtime, dev only) ▸
# these env vars ▸ built-in localhost defaults. See src/config/api.js.

# REST base — must include /api/v1.
VITE_API_BASE_URL=http://localhost:8000/api/v1

# WebSocket base (chat). Optional — if omitted, derived from VITE_API_BASE_URL.
# Set explicitly only when REST and WS live on different hosts (rare).
VITE_WS_BASE_URL=ws://localhost:8000

# ── Sample prod values (already committed in .env.production):
# VITE_API_BASE_URL=https://api.e-learn.uz/api/v1
# VITE_WS_BASE_URL=wss://api.e-learn.uz
